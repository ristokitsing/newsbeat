# newsbeat-digest Python/Docker processor configuration.
# The native app stores its feed settings separately and does not read this file.
ANTHROPIC_API_KEY=
AI_DIGEST_PAGES_URL=https://news.example.com
AI_DIGEST_TIMEZONE=Europe/Tallinn
AI_DIGEST_MAX_ITEMS=8
AI_DIGEST_SCORE_MODEL=claude-haiku-4-5
AI_DIGEST_BRIEF_MODEL=claude-haiku-4-5

# Docker/VPS file ownership for backend-generated state.
NEWSBEAT_DIGEST_UID=1000
NEWSBEAT_DIGEST_GID=1000
