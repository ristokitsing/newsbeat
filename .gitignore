# Local secrets and Python environment.
.env
.venv/

# newsbeat-digest runtime state. These files are generated and persisted
# outside source control on the machine that runs the processor.
data/
feed/
digests/
digest.db

# Python packaging metadata generated by `pip install -e .` or package builds.
# It is safe to delete; setuptools recreates it when the package is installed.
*.egg-info/
build/
dist/

# Python bytecode, test, and coverage caches.
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# macOS, Swift, Xcode, and IDE artifacts.
.DS_Store
.build/
DerivedData/
xcuserdata/
*.xcresult/

# XcodeGen outputs. Source configuration remains in project.yml.
/app/Newsbeat/Newsbeat.xcodeproj/
/app/Newsbeat/generated/
